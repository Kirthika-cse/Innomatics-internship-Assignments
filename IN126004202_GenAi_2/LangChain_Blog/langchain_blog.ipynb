    {
      "cell_type": "markdown",
      "source": [
        "## 6: Create a Chain"
      ],
      "metadata": {
        "id": "NOImGqLUQGKs"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def chain(topic):\n",
        "    formatted_prompt = prompt.format(topic=topic)\n",
        "    return llm(formatted_prompt)"
