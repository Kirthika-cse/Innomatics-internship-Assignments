      "cell_type": "markdown",
      "source": [
        "### 4: Create Prompt Template"
      ],
      "metadata": {
        "id": "2q9DjRBOP_XX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from langchain_core.prompts import PromptTemplate\n",
        "\n",
        "prompt = PromptTemplate.from_template(\n",
        "    \"Explain {topic} in simple terms\"\n",
        ")"
      ],
      "metadata": {
        "id": "sNDfhxvAOIlx"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "formatted_prompt = prompt.format(topic=\"Artificial Intelligence\")\n",
        "print(formatted_prompt)\n"
      ],
