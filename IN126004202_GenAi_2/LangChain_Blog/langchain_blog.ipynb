      "cell_type": "code",
      "source": [
        "from transformers import pipeline\n",
        "\n",
        "# Load model\n",
        "pipe = pipeline(\"text-generation\", model=\"gpt2\")\n",
        "\n",
        "# Create LLM function\n",
        "def llm(prompt):\n",
        "    return pipe(prompt, max_length=100)[0]['generated_text']"
